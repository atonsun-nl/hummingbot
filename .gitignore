```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# Dependencies
venv/
.venv/
node_modules/

# Build artifacts
dist/
build/
target/

# Coverage reports
.coverage
coverage/
htmlcov/

# Testing
.pytest_cache/
.mypy_cache/
.hypothesis/

# OS generated files
.DS_Store
Thumbs.db

# IDE specific
.vscode/
.idea/
*.swp
*.swo
*.tmp
```